generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum DomainType {
  SUBDOMAIN
  CUSTOM
}

enum LeadStatus {
  NEW
  CONTACTED
  APPOINTMENT
  WON
  LOST
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  domains  Domain[]
  leads    Lead[]
  site     Site?
  listings Listing[]

  contacts           Contact[]
  savedSearches      SavedSearch[]
  savedSearchMatches SavedSearchMatch[]

  conversations        Conversation[]
  messages             Message[]
  engagementEvents     EngagementEvent[]
  messagingProfile     TenantMessagingProfile?
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assignedConversations Conversation[]

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Domain {
  id        String     @id @default(cuid())
  hostname  String     @unique
  type      DomainType
  verified  Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Site {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  brandName    String  @default("Demo Realty")
  tagline      String  @default("Helping you find home.")
  primaryColor String  @default("#111827")
  logoUrl      String?
  phone        String?
  email        String?
  template     String  @default("modern")
}

model Listing {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  source           String? // e.g. PILLAR9
  sourceListingKey String? // unique per tenant+source
  lastSyncedAt     DateTime?
  isHidden         Boolean   @default(false)
  featured         Boolean   @default(false)

  status   String  @default("ACTIVE")
  title    String
  address  String?
  city     String?
  province String?
  postal   String?

  price       Int?
  beds        Int?
  baths       Int?
  sqft        Int?
  imageUrl    String?
  description String?
  viewCount   Int     @default(0)
  conversations Conversation[]

  leads              Lead[]
  savedSearchMatches SavedSearchMatch[]

  @@unique([tenantId, source, sourceListingKey], name: "listing_source_key_per_tenant")
}

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fullName String?
  email    String?
  phone    String?
  message  String?
  source   String?
  status   LeadStatus @default(NEW)

  // ✅ attribution (site + ads)
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  gclid  String?
  gbraid String?
  wbraid String?
  fbclid String?

  landingPath String?
  referrer    String?
  userAgent   String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  conversations Conversation[]
}

enum Channel {
  EMAIL
  SMS
}

model Contact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  fullName String?
  email    String?
  phone    String?

  leads         Lead[]
  savedSearches SavedSearch[]
  conversations Conversation[]
}

model SavedSearch {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  name String

  criteria Json

  isActive Boolean @default(true)

  matches SavedSearchMatch[]
  lastRunAt DateTime?

  @@index([tenantId])
  @@index([contactId])
}

model SavedSearchMatch {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  savedSearchId String
  savedSearch   SavedSearch @relation(fields: [savedSearchId], references: [id], onDelete: Cascade)

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  isNew Boolean @default(true)

  // prevents duplicate matches for same search+listing
  @@unique([savedSearchId, listingId])
  @@index([tenantId])
  @@index([listingId])
}

enum ConversationStatus {
  OPEN
  CLOSED
  ARCHIVED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  DRAFT
  QUEUED
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

enum MessagingProvider {
  TWILIO
  SENDGRID
  MAILGUN
  SES
  OTHER
}

enum EngagementType {
  DELIVERED
  OPEN
  CLICK
  BOUNCE
  REPLY
  STOP
  UNSUBSCRIBE
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  channel Channel

  status ConversationStatus @default(OPEN)

  // assignment / workflow
  assignedUserId String?
  assignedUser   User? @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)

  // AI control (Phase 1: use OFF/DRAFTS behavior in app code; keep fields for Phase 2+)
  aiMode         String?   // "OFF" | "DRAFTS" | "AUTO" (string keeps it flexible)
  aiPausedUntil  DateTime?

  lastMessageAt  DateTime?
  lastInboundAt  DateTime?
  lastOutboundAt DateTime?

  // optional context
  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  leadId String?
  lead   Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  messages         Message[]
  engagementEvents EngagementEvent[]

  @@index([tenantId, contactId])
  @@index([tenantId, lastMessageAt])
  @@index([tenantId, status])
}

model Message {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  channel    Channel
  direction  MessageDirection
  status     MessageStatus @default(QUEUED)

  // normalized addressing (phone numbers / email addresses)
  from String
  to   String

  subject String?
  text    String?
  html    String?

  // provider metadata for webhooks + reconciliation
  provider          MessagingProvider @default(OTHER)
  providerMessageId String?

  errorCode    String?
  errorMessage String?

  sentAt      DateTime?
  deliveredAt DateTime?
  failedAt    DateTime?

  // email tracking (open/click)
  trackingId String? @unique

  engagementEvents EngagementEvent[]

  @@index([tenantId, conversationId, createdAt])
  @@index([tenantId, createdAt])
  @@unique([provider, providerMessageId])
}

model EngagementEvent {
  id         String   @id @default(cuid())
  occurredAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type EngagementType

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  messageId String?
  message   Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  meta Json?

  @@index([tenantId, occurredAt])
  @@index([tenantId, conversationId, occurredAt])
  @@index([tenantId, messageId, occurredAt])
}

model TenantMessagingProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // SMS identity
  smsFromNumber String? // E.164, ex: +1403...
  smsProvider   MessagingProvider @default(OTHER)

  // Email identity
  emailFromAddress String?
  emailFromName    String?
  replyToAddress   String?
  emailProvider    MessagingProvider @default(OTHER)

  // optional flags
  enableSms   Boolean @default(false)
  enableEmail Boolean @default(false)
}