generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum DomainType {
  SUBDOMAIN
  CUSTOM
}

enum LeadStatus {
  NEW
  CONTACTED
  APPOINTMENT
  WON
  LOST
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  domains            Domain[]
  leads              Lead[]
  site               Site?
  listings           Listing[]
  contacts           Contact[]
  savedSearches      SavedSearch[]
  savedSearchMatches SavedSearchMatch[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Domain {
  id        String     @id @default(cuid())
  hostname  String     @unique
  type      DomainType
  verified  Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Site {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  brandName    String  @default("Demo Realty")
  tagline      String  @default("Helping you find home.")
  primaryColor String  @default("#111827")
  logoUrl      String?
  phone        String?
  email        String?
  template     String  @default("modern")
}

model Listing {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // ✅ Sync identity
  source           String    @default("MANUAL")
  sourceListingKey String
  lastSyncedAt     DateTime?
  isHidden         Boolean   @default(false)
  featured         Boolean   @default(false)

  // MVP fields
  status   String  @default("ACTIVE") // ACTIVE, SOLD, DRAFT, INACTIVE
  title    String
  address  String?
  city     String?
  province String?
  postal   String?

  price       Int?
  beds        Int?
  baths       Int?
  sqft        Int?
  imageUrl    String?
  description String?

  viewCount          Int                @default(0)
  leads              Lead[]
  savedSearchMatches SavedSearchMatch[]

  // ✅ Prevent duplicates per tenant+source+key
  @@unique([tenantId, source, sourceListingKey], name: "listing_source_key_per_tenant")
}

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fullName String?
  email    String?
  phone    String?
  message  String?
  source   String?
  status   LeadStatus @default(NEW)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

enum Channel {
  EMAIL
  SMS
}

model Contact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  fullName String?
  email    String?
  phone    String?

  // Optional: for CRM pipeline later (NEW, QUALIFIED, etc.)
  stage String @default("NEW")

  savedSearches SavedSearch[]
  leads         Lead[]

  @@index([tenantId])
}

model SavedSearch {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  name String? // optional label like "NW Calgary under 700k"

  // Common filters (indexed-ish)
  city         String?
  minPrice     Int?
  maxPrice     Int?
  minBeds      Int?
  maxBeds      Int?
  minBaths     Int?
  maxBaths     Int?
  minSqft      Int?
  maxSqft      Int?
  propertyType String? // "DETACHED", "CONDO", etc.

  // Flexible filters (areas, keywords, features)
  filters Json?

  matches SavedSearchMatch[]
}

model SavedSearchMatch {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  savedSearchId String
  savedSearch   SavedSearch @relation(fields: [savedSearchId], references: [id], onDelete: Cascade)

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  // Prevent duplicates: one match per (search, listing)
  @@unique([savedSearchId, listingId], name: "uniq_match_per_search_listing")
}
